								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="toggle sr on off response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="SR toggled on/off" /><TextBox x:Name="RespToggleSrInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
							</StackPanel>

							<!-- COMMANDS -->
							<StackPanel x:Name="CatCommands" Visibility="Collapsed">
								<TextBlock Margin="0,0,0,10" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#ADADB8" Text="COMMANDS" />
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4">
									<Grid>
										<Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="160" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
										<TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="On" HorizontalAlignment="Center" VerticalAlignment="Center" />
