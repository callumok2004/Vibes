										<StackPanel VerticalAlignment="Center">
											<TextBlock FontFamily="Segoe UI" FontSize="13" Foreground="#EFEFF1" Text="Minimize to tray" />
											<TextBlock Margin="0,2,0,0" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Hide to system tray on minimize" />
										</StackPanel>
										<CheckBox x:Name="MinimizeToTrayCheck" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Checked="Cfg_CheckChanged" Unchecked="Cfg_CheckChanged" />
									</Grid>
