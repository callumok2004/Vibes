									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Per-user cooldown active" /><TextBox x:Name="RespUserCooldownInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="max requests user hit response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="User hit max requests" /><TextBox x:Name="RespMaxReqInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="queue full response">
