							<!-- APP -->
							<StackPanel x:Name="CatApp" Visibility="Collapsed">
								<TextBlock Margin="0,0,0,10" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#ADADB8" Text="APP" />
								<Border Margin="0,0,0,2" Padding="18,12" Background="#0E0E10" CornerRadius="4" Tag="start windows startup autostart launch login">
									<Grid><Grid.ColumnDefinitions><ColumnDefinition Width="200" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
										<StackPanel VerticalAlignment="Center">
											<TextBlock FontFamily="Segoe UI" FontSize="13" Foreground="#EFEFF1" Text="Start with Windows" />
											<TextBlock Margin="0,2,0,0" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Launch on login" />
										</StackPanel>
										<CheckBox x:Name="StartWithWindowsCheck" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Checked="Cfg_CheckChanged" Unchecked="Cfg_CheckChanged" />
									</Grid>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,12" Background="#0E0E10" CornerRadius="4" Tag="minimize tray system tray hide">
