								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="vote skip cast response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Vote skip cast" /><TextBox x:Name="RespVoteSkipInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="song liked heart response">
