									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Song is explicit" /><TextBox x:Name="RespExplicitInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="song too long response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Song too long" /><TextBox x:Name="RespTooLongInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="cooldown global response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Global cooldown active" /><TextBox x:Name="RespCooldownInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
