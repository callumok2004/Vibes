										</StackPanel>
										<Button Grid.Column="1" VerticalAlignment="Center" Click="CheckForUpdates_Click" Content="Check for Updates" Style="{StaticResource ActionBtn}" />
									</Grid>
								</Border>
							</StackPanel>

						</StackPanel>
					</ScrollViewer>
				</Grid>

				</Grid>

			</Grid>

			<!-- SETUP GUIDE -->
			<ScrollViewer x:Name="GuidePanel" Grid.Row="2" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
				<StackPanel Margin="40,32,40,32" MaxWidth="700" HorizontalAlignment="Center">
					<TextBlock FontFamily="Segoe UI" FontSize="22" FontWeight="Bold" Foreground="#EFEFF1" Text="Setup Guide" />
					<TextBlock Margin="0,6,0,28" FontFamily="Segoe UI" FontSize="13" Foreground="#ADADB8" TextWrapping="Wrap" Text="Follow these steps to connect Spotify and Twitch. Spotify requires a free developer app - Twitch just needs your channel name." />

					<TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#1DB954" Text="Spotify" />
					<Rectangle Margin="0,8,0,16" Height="1" Fill="#2D2D35" />
					<TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#EFEFF1" Text="Step 1 - Create a Spotify app" />
					<TextBlock Margin="0,6,0,0" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Go to </Run><Run Foreground="#1DB954" FontWeight="SemiBold">developer.spotify.com/dashboard</Run><Run> and log in. Click </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Create app</Run><Run>. Give it any name, then under </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Redirect URIs</Run><Run> add:</Run></TextBlock>
					<Border Margin="0,8,0,8" Padding="12,8" Background="#0E0E10" CornerRadius="4"><TextBlock FontFamily="Consolas" FontSize="12" Foreground="#9146FF" Text="http://127.0.0.1:8888/callback/" /></Border>
					<TextBlock Margin="0,0,0,0" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>(Change </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">8888</Run><Run> to match Callback Port in Config → Spotify.) Set the API to </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Web API</Run><Run> and save.</Run></TextBlock>
					<TextBlock Margin="0,16,0,0" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#EFEFF1" Text="Step 2 - Paste your Client ID" />
					<TextBlock Margin="0,6,0,16" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>On your app dashboard, copy the </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Client ID</Run><Run> and paste it into </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Spotify → Client ID</Run><Run>.</Run></TextBlock>
					<TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#EFEFF1" Text="Step 3 - Authorize" />
					<TextBlock Margin="0,6,0,24" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Go to </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Spotify</Run><Run> and click </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Connect</Run><Run>. Approve access in the browser - the tab closes automatically.</Run></TextBlock>

					<TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#9146FF" Text="Twitch" />
					<Rectangle Margin="0,8,0,16" Height="1" Fill="#2D2D35" />
					<TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#EFEFF1" Text="Step 1 - Set your channel name" />
					<TextBlock Margin="0,6,0,16" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Enter your Twitch username in </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Twitch → Channel</Run><Run>.</Run></TextBlock>
					<TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="#EFEFF1" Text="Step 2 - Authorize and Connect" />
					<TextBlock Margin="0,6,0,24" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Click </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Connect</Run><Run> in </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Twitch</Run><Run>. Log in with your broadcaster account and approve. If using a bot account, enable </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Use Bot Account</Run><Run>, enter the bot's username, then click </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Authorize Bot</Run><Run> and log in with that account.</Run></TextBlock>

					<TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#EFEFF1" Text="Song Requests" />
					<Rectangle Margin="0,8,0,16" Height="1" Fill="#2D2D35" />
					<TextBlock Margin="0,0,0,6" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Once both are connected, viewers type </Run><Run FontFamily="Consolas" Foreground="#9146FF">!sr song name</Run><Run> in chat and Vibes adds it to your Spotify queue.</Run></TextBlock>
					<TextBlock Margin="0,0,0,6" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>Adjust the command trigger, cooldowns, user levels, and queue limits in </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Requests</Run><Run> and </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Limits</Run><Run>.</Run></TextBlock>
					<TextBlock Margin="0,0,0,32" FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" TextWrapping="Wrap" xml:space="preserve"><Run>To use Channel Point rewards, set the mode in </Run><Run FontWeight="SemiBold" Foreground="#EFEFF1">Config → Requests → Request Mode</Run><Run> and paste your reward ID.</Run></TextBlock>
				</StackPanel>
			</ScrollViewer>

			<!-- Status bar - -->
			<Border Grid.Row="3" Background="#0E0E10" BorderBrush="#2D2D35" BorderThickness="0,1,0,0">
				<Grid Margin="14,0" Height="28">
					<StackPanel VerticalAlignment="Center" Orientation="Horizontal">
						<Ellipse x:Name="TwitchDot"  Width="7" Height="7" Margin="0,0,5,0" Fill="#4A4A55" />
						<TextBlock x:Name="TwitchStatusText"  Margin="0,0,16,0" FontFamily="Segoe UI" FontSize="11" Foreground="#ADADB8" Text="Twitch: disconnected" />
						<Ellipse x:Name="SpotifyDot" Width="7" Height="7" Margin="0,0,5,0" Fill="#4A4A55" />
						<TextBlock x:Name="SpotifyStatusText" Margin="0,0,16,0" FontFamily="Segoe UI" FontSize="11" Foreground="#ADADB8" Text="Spotify: disconnected" />
						<Ellipse x:Name="SrDot"      Width="7" Height="7" Margin="0,0,5,0" Fill="#4A4A55" />
						<TextBlock x:Name="SrStatusText"      Margin="0,0,16,0" FontFamily="Segoe UI" FontSize="11" Foreground="#ADADB8" Text="Requests: off" />
						<Ellipse x:Name="BotDot"     Width="7" Height="7" Margin="0,0,5,0" Fill="#4A4A55" />
						<TextBlock x:Name="BotStatusText"     FontFamily="Segoe UI" FontSize="11" Foreground="#ADADB8" Text="Bot: not connected" />
					</StackPanel>
					<TextBlock x:Name="QueueStatusText" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" />
				</Grid>
			</Border>
		</Grid>
	</Border>
</Window>




