								<TextBlock Margin="0,0,0,10" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="0 = unlimited" />
								<Border Margin="0,0,0,2" Padding="18,14" Background="#0E0E10" CornerRadius="4" Tag="max requests viewer follower subscriber vip moderator broadcaster limits">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
											<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="Auto" />
										</Grid.RowDefinitions>
										<TextBlock Grid.Column="0" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Viewer"      HorizontalAlignment="Center" />
										<TextBlock Grid.Column="1" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Follower"    HorizontalAlignment="Center" />
										<TextBlock Grid.Column="2" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Sub T1"      HorizontalAlignment="Center" />
										<TextBlock Grid.Column="3" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Sub T2"      HorizontalAlignment="Center" />
										<TextBlock Grid.Column="4" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Sub T3"      HorizontalAlignment="Center" />
										<TextBlock Grid.Column="5" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="VIP"         HorizontalAlignment="Center" />
										<TextBlock Grid.Column="6" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Mod"         HorizontalAlignment="Center" />
										<TextBlock Grid.Column="7" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Broadcaster" HorizontalAlignment="Center" />
										<TextBox x:Name="MaxReqViewer"      Grid.Row="2" Grid.Column="0" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqFollower"    Grid.Row="2" Grid.Column="1" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqSub"         Grid.Row="2" Grid.Column="2" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqSubT2"       Grid.Row="2" Grid.Column="3" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqSubT3"       Grid.Row="2" Grid.Column="4" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqVip"         Grid.Row="2" Grid.Column="5" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqMod"         Grid.Row="2" Grid.Column="6" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
										<TextBox x:Name="MaxReqBroadcaster" Grid.Row="2" Grid.Column="7" Margin="3,0" TextAlignment="Center" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" />
									</Grid>
								</Border>
							</StackPanel>

							<!-- BOT RESPONSES -->
							<StackPanel x:Name="CatResponses" Visibility="Collapsed">
								<TextBlock Margin="0,0,0,6" FontFamily="Segoe UI" FontSize="11" FontWeight="Bold" Foreground="#ADADB8" Text="BOT RESPONSES" />
								<TextBlock Margin="0,0,0,10" FontFamily="Segoe UI" FontSize="11" Foreground="#4A4A55" Text="Placeholders: {user} {artist} {title} {song} {pos} {ttp} {cd} {max} {level} {votes} {needed} {state}" TextWrapping="Wrap" />
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="success added queue response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="Song added successfully" /><TextBox x:Name="RespSuccessInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
