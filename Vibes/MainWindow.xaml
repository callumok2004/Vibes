								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="song now playing response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="!song - now playing" /><TextBox x:Name="RespSongInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="next song up next response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="!next - next song" /><TextBox x:Name="RespNextInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="position queue pos response">
									<StackPanel><TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#ADADB8" Text="!pos - queue position" /><TextBox x:Name="RespPosInput" Margin="0,6,0,0" Style="{StaticResource SettingsInput}" TextChanged="Cfg_Changed" /></StackPanel>
								</Border>
								<Border Margin="0,0,0,2" Padding="18,10" Background="#0E0E10" CornerRadius="4" Tag="queue list response">
